# Crypto Daytrading Platform — Environment Configuration

# ============================================================================
# BINANCE API (Get keys from https://www.binance.com/en/account/api-management)
# ============================================================================

# Binance REST API key and secret
# For paper trading: use testnet keys (https://testnet.binance.vision/)
# For live trading: use real account keys (KEEP SECURE!)
BINANCE_API_KEY=your_api_key_here_do_not_commit
BINANCE_API_SECRET=your_api_secret_here_do_not_commit

# Use Binance testnet for paper trading (no real money risk)
# Set to 'false' for live trading on real account
BINANCE_TESTNET=true

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================

# Trading mode: 'paper' (simulated) or 'live' (real Binance account)
TRADING_MODE=paper

# Initial capital (virtual for paper, real money for live)
# Paper trading: €10,000 virtual
# Live trading: €1,000 real (start small)
INITIAL_CAPITAL=10000

# Which strategy to use: momentum | meanreversion | grid
STRATEGY=momentum

# Maximum daily loss as percentage of account before auto-stop
# Example: 5.0 means if you lose 5% of account in one day, stop trading
MAX_DAILY_LOSS_PCT=5.0

# Maximum concurrent positions (limits exposure)
MAX_POSITIONS=5

# Position size as percentage of account per trade
# Example: 2.0 means each trade uses 2% of account
POSITION_SIZE_PCT=2.0

# Profit target (percentage)
PROFIT_TARGET_PCT=1.5

# Stop loss (percentage)
STOP_LOSS_PCT=2.0

# ============================================================================
# API & SYSTEM
# ============================================================================

# API server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ============================================================================
# HIGH AVAILABILITY (DUAL MACHINE)
# ============================================================================

# Machine identifier: 'main' (primary) or 'backup' (standby)
MACHINE_ID=main

# URL of backup machine (for main machine to send heartbeat)
# Or URL of main machine (for backup to check status)
BACKUP_MACHINE_URL=http://backup-machine:8000

# Heartbeat interval in seconds (how often to check if other machine is alive)
HEARTBEAT_INTERVAL=10

# Failover threshold: missed heartbeats before switching to backup
# Example: 3 means if main doesn't send heartbeat for 30 seconds (3 × 10s), failover
FAILOVER_THRESHOLD=3

# ============================================================================
# NOTIFICATIONS (OPTIONAL)
# ============================================================================

# Email for critical alerts (optional)
# Leave empty to skip email notifications
ALERT_EMAIL=your.email@example.com

# Discord webhook for alerts (optional)
# Get from Discord server settings → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable detailed logging (more output, slower)
DEBUG=false

# Mock Binance API (for testing without real API calls)
MOCK_BINANCE=false

# Database URL (if using database instead of JSON files)
# Format: postgresql://user:password@localhost:5432/crypto_trading
DATABASE_URL=

# ============================================================================
# Notes
# ============================================================================
#
# SECURITY:
# - Never commit .env file to git (it's in .gitignore)
# - API keys are sensitive: treat like passwords
# - For live trading: keep backup copy in safe location
# - Rotate API keys regularly
#
# PAPER VS LIVE:
# - Paper trading: TRADING_MODE=paper, BINANCE_TESTNET=true
# - Live trading: TRADING_MODE=live, BINANCE_TESTNET=false
#
# HA SETUP:
# - Main machine: MACHINE_ID=main
# - Backup machine: MACHINE_ID=backup
# - Both machines must know each other's URLs
#
