# Crypto Daytrading - Environment Configuration
# Copy this to .env and fill in your values

# ============================================================================
# TRADING CONFIGURATION - SOURCE OF TRUTH FOR BOTH PRIMARY & BACKUP MACHINES
# ============================================================================
# These values are loaded by BOTH machines at startup from .env
# Changes via API dashboard are synced to backup automatically
# Restart both machines to load new .env values

# Entry & Exit Decision Parameters
# IMPORTANT: All percentages stored as percentages (e.g., 2.5 = 2.5%), NOT decimals
ENTRY_THRESHOLD=60.0                    # Min signal strength (0-100) to open position
EXIT_PROFIT_TARGET=3.0                  # Sell at this % profit (3.0 = 3% per trade)
EXIT_STOP_LOSS=3.0                      # Sell at this % loss (3.0 = 3% per trade)

# Risk Management Parameters
POSITION_SIZE_PCT=2.5                   # % of equity per trade (2.5 = risk 2.5% per position)
MAX_POSITIONS=8                         # Max simultaneous open trades (2.5% × 8 = 20% total portfolio risk)
MAX_DAILY_LOSS_PCT=5.0                  # Auto-stop if daily loss exceeds this %

# Safety & Data Quality Gates
QUALITY_GATE_ENTRY=90.0                 # Min data quality % to OPEN position (strict)
QUALITY_GATE_EXIT=60.0                  # Min data quality % to CLOSE position (permissive)

# Trading Frequency & Execution
LOOP_SLEEP_SECONDS=10.0                 # Seconds between trading loop iterations (10 = ~6 trades/min max)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT # Comma-separated symbols to monitor

# ============================================================================
# PLATFORM CONFIGURATION
# ============================================================================

TRADING_MODE=paper                      # 'paper' or 'live'
INITIAL_CAPITAL=10000.0                 # Starting capital in € for paper trading

# ============================================================================
# BINANCE API CONFIGURATION
# ============================================================================
# Get credentials from https://binance.com/en/user/settings/manage-api-key

BINANCE_API_KEY=your_api_key_here       # Binance API key (leave empty for paper trading)
BINANCE_API_SECRET=your_secret_here     # Binance API secret (leave empty for paper trading)
BINANCE_TESTNET=true                    # Use Binance testnet (true) or mainnet (false)

# ============================================================================
# HA (HIGH AVAILABILITY) CONFIGURATION
# ============================================================================
# Primary machine syncs to backup via HTTP POST to /api/autonomous/config/sync

MACHINE_ID=main                         # 'main' (primary) or 'backup' (secondary)
BACKUP_MACHINE_URL=http://192.168.3.25:8002  # Backup machine HTTP endpoint
HEARTBEAT_INTERVAL=10                   # Seconds between HA health checks

# ============================================================================
# API CONFIGURATION
# ============================================================================

API_HOST=0.0.0.0                        # Bind to all interfaces
API_PORT=8001                           # HTTP port for API & dashboard

# ============================================================================
# API AUTHENTICATION (Demo tokens for Phase 1)
# ============================================================================
# These tokens control dashboard access. Change them for production.

AUTH_ADMIN_TOKEN=admin-token-123        # Full access
AUTH_ANALYST_TOKEN=analyst-token-456    # Read-only
AUTH_TRADER_TOKEN=trader-token-789      # Execute trades
AUTH_VIEWER_TOKEN=viewer-token-000      # View-only

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO                          # DEBUG, INFO, WARNING, ERROR, CRITICAL
DEBUG=false                             # Enable debug logging

# ============================================================================
# NOTES
# ============================================================================
#
# SYNC BEHAVIOR:
# ✅ On startup: Both machines load from this .env file
# ✅ During operation: Primary → Backup sync via HTTP POST
# ✅ After restart: Both reload from .env (guaranteed sync)
#
# IF BACKUP IS NOT REACHABLE:
# - Primary continues trading normally
# - Changes are queued and synced when backup recovers
# - Manual sync available via /api/autonomous/config/sync endpoint
#
# HA FAILOVER:
# - If primary fails, backup takes over automatically
# - Both have same config from .env
# - Switch backup MACHINE_ID=main to make it primary
#
