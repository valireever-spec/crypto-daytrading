# Trading Configuration (Optimized)
TRADING_MODE=paper
INITIAL_CAPITAL=10000.0
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT

# Risk Management
MAX_DAILY_LOSS_PCT=5.0
MAX_POSITIONS=5
POSITION_SIZE_PCT=0.05

# Entry/Exit Thresholds
ENTRY_THRESHOLD=60.0
EXIT_PROFIT_TARGET=0.03
EXIT_STOP_LOSS=0.02

# Binance Configuration
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Machine HA Configuration
MACHINE_ID=main
PRIMARY_API_URL=http://127.0.0.1:8001
BACKUP_MACHINE_URL=http://192.168.3.25:8002
BACKUP_API_URL_LOCAL=http://192.168.3.25:8002
HEARTBEAT_INTERVAL=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=trading

# Logging
LOG_LEVEL=INFO
DEBUG=false
